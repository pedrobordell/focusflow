# Copia este archivo a .env y rellena los valores reales.
# El archivo .env NO se sube al repositorio (ver .gitignore).

# Clave secreta para firmar los JWT. Genera una con:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=pon-aqui-una-clave-larga-y-aleatoria

# Cadena de conexion a MySQL:
#   mysql+pymysql://USUARIO:CONTRASENA@HOST:PUERTO/BASEDEDATOS
DATABASE_URL=mysql+pymysql://usuario:contrasena@localhost:3306/focusflow
